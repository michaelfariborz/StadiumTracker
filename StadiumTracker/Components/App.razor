<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (function () {
            window.toggleTheme = function () {
                var h = document.documentElement;
                var t = h.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
                h.setAttribute('data-bs-theme', t);
                localStorage.setItem('theme', t);
            };

            function applyTheme() {
                var t = localStorage.getItem('theme') || 'light';
                if (document.documentElement.getAttribute('data-bs-theme') !== t) {
                    document.documentElement.setAttribute('data-bs-theme', t);
                }
            }

            applyTheme();

            // Blazor enhanced navigation morphs <html> from server HTML (which has no
            // data-bs-theme), stripping our attribute. MutationObserver fires as a
            // microtask — before the browser paints — so the attribute is restored
            // with no visible flash regardless of which navigation event name .NET uses.
            new MutationObserver(applyTheme).observe(
                document.documentElement,
                { attributes: true, attributeFilter: ['data-bs-theme'] }
            );
        })();
    </script>
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
